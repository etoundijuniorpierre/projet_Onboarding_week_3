<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1752598576967-1" author="etoun">
        <createSequence incrementBy="50" sequenceName="checkpoint_entity_seq" startValue="1"/>
    </changeSet>
    <changeSet id="1752598576967-2" author="etoun">
        <createTable tableName="checkpoint_entity">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="checkpoint_entity_pkey"/>
            </column>
            <column name="location_entity_id" type="BIGINT"/>
            <column name="package_entity_id" type="BIGINT"/>
            <column name="pass_date_time" type="timestamp"/>
        </createTable>
    </changeSet>

</databaseChangeLog>